# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Build output - acloud binaries
acloud
acloud-*

# Configuration files (for testing)
.acloud.yaml
*.yaml.bak

# Log files
*.log

# Temporary files
tmp/
temp/
dist/

# Docusaurus website (docs/website/)
docs/website/node_modules/
docs/website/build/
docs/website/.docusaurus/
docs/website/.cache-loader/
docs/website/.env.local
docs/website/.env.development.local
docs/website/.env.test.local
docs/website/.env.production.local
docs/website/npm-debug.log*
docs/website/yarn-debug.log*
docs/website/yarn-error.log*
docs/website/.npm/
docs/website/.yarn/
docs/website/.pnp.*
docs/website/.yarn/cache
docs/website/.yarn/unplugged
docs/website/.yarn/build-state.yml
docs/website/.yarn/install-state.gz
docs/website/.pnp.js

# CI-created versioned documentation files
# These are generated during the release workflow and don't need to be committed
docs/website/versioned_docs/
docs/website/versioned_sidebars/
docs/website/versions.json
# Versioned translations (created by CI, but keep current/ translations)
docs/website/i18n/*/docusaurus-plugin-content-docs/version-*/
docs/website/i18n/*/docusaurus-plugin-content-docs/version-*.json
